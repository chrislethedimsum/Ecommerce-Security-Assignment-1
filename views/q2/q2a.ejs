<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Register - E-Commerce</title>
    <style>
        body {font-family: Arial, sans-serif; margin: 0; padding: 0;}
        .box {padding:20px;}
        h2 {margin-top: 0; color: #0073aa;}
        .form-group {margin-bottom: 14px;}
        .form-group label {display: block; margin-bottom: 6px; color: #333;}
        .form-group input {width: 100%; padding: 9px 10px; border: 1px solid #b7c2cc; border-radius: 4px; font-size: 14px;}
        button {padding: 10px; background-color: #0073aa; border: none; color: #fff; font-size: 15px; border-radius: 4px; cursor: pointer;}
        button:hover {background-color: #005f8c;}
        label {font-weight: bold;}
        .error {color: red; margin-top: 10px;}
    </style>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <script>
        function onSubmitForm(e) {
            // Get reCAPTCHA response
            const recaptchaToken = grecaptcha.getResponse();
            
            if (!recaptchaToken) {
                alert('Please complete the reCAPTCHA verification');
                e.preventDefault();
                return false;
            }
            return true;
        }
    </script>
</head>
<body>
    <div class="box">
        <h2>Create Account</h2>
        <form action="/q2a" method="post" onsubmit="return onSubmitForm(event)">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required />
            </div>
            <div class="form-group">
                <label for="confirm_password">Re-type Password</label>
                <input type="password" id="confirm_password" name="confirm_password" required />
                <p>Minimum 10 characters. Must include uppercase, lowercase and number(s).</p>
            </div>
            <div class="form-group">
                <div class="g-recaptcha" data-sitekey="6LdbeJssAAAAABEaV48qELRspnhsQJmBzXblwpz-"></div>
            </div>
            <button type="submit">Create Account</button>
        </form>
    </div>
</body>
</html>
