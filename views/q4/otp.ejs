<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Login - E-Commerce</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
      }
      .box {
        padding: 20px;
      }
      input{
        width: 100%;
        height: 30px;
      }
      h1{
        color: #0073aa;
      }
      h3{
        padding-top: 30px;  
        font-weight: lighter;
        color: #0073aa;
      }
      .text{
        padding-top: 30px;
        padding-bottom: 5px;
      }
    </style>
  </head>
  <body>
    <div class="box">
      <h1>Two Factor Authentication</h1>
      <h3>Verify your identity</h3>
      <hr />
      <form action="/otp" method="post">
        <p>Open the Google Authenticator app on your device to view your authentication code and enter it here to verify your identity</p>
        <div class="text"><strong>Two Factor Code</strong></div>
        <input type="text" name="otp" required>
        <button type="submit" style="margin-right: 8px; margin-top: 10px">Verify Code</button>
      </form>
    </div>
  </body>
</html>
